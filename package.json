{
  "name": "vscode-auto-scroll",
  "displayName": "AutoScroll",
  "description": "auto scroll to the end of file",
  "version": "1.3.0",
  "publisher": "pejmannikram",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/PejmanNik/vscode-autoScroll.git"
  },
  "keywords": [
    "Log",
    "Log File",
    "Scroll",
    "Auto Scroll",
    "End of file"
  ],
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:log"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "autoScroll.disable",
        "title": "Disable Auto Scroll",
        "category": "Auto Scroll"
      },
      {
        "command": "autoScroll.enable",
        "title": "Enable Auto Scroll",
        "category": "Auto Scroll"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "AutoScroll",
      "properties": {
        "autoscroll.keepLastLineInCenter": {
          "type": "boolean",
          "default": true,
          "description": "Keep last line in center of view."
        },
        "autoscroll.autoEnableForLogs": {
          "type": "boolean",
          "default": false,
          "description": "Automatically enable auto-scroll for log files."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.mjs",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.mjs --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.mjs --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "log-builder": "node log-builder.mjs"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.0.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.56.1"
  }
}
